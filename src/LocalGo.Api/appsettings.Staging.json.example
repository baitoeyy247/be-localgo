{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "ConnectionStrings": {
    "Default": "Host=YOUR-NEON-HOST.neon.tech;Database=localgo;Username=YOUR_USER;Password=YOUR_PASSWORD;SSL Mode=Require",
    "Redis": "YOUR_UPSTASH_REDIS_URL_OR_LEAVE_EMPTY"
  },

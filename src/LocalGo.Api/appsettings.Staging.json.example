    "ExpiresDays": 7
  },
  "Line": {
    "ChannelId": "2010177240",
    "ChannelSecret": "YOUR_LINE_CHANNEL_SECRET",
    "LiffId": "2010177240-Bu98ZCLT",
    "MessagingAccessToken": "YOUR_MESSAGING_ACCESS_TOKEN"
  },
  "Cors": {
